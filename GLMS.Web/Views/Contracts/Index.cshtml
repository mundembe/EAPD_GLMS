@model IEnumerable<GLMS.Web.Models.Contract>

<h2>Contracts</h2>

<a asp-action="Create" class="btn btn-primary">Create Contract</a>

<table class="table">
    <thead>
        <tr>
            <th>Client</th>
            <th>Status</th>
            <th>Service Level</th>
            <th>Agreement</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var contract in Model)
        {
            <tr>
                <td>@contract.ClientId</td>
                <td>@contract.Status</td>
                <td>@contract.ServiceLevel</td>
                <td>
                    @if (!string.IsNullOrEmpty(contract.SignedAgreementPath))
                    {
                        <a asp-action="Download" asp-route-id="@contract.Id" class="btn btn-sm btn-success">
                            Download PDF
                        </a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>